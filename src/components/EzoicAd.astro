---
interface Props {
  slotId: number;
  className?: string;
}

const { slotId, className = '' } = Astro.props;
---

<div
  class:list={['ezoic-ad-wrapper', className]}
  id={`ezoic-pub-ad-placeholder-${slotId}`}
>
  <div class="ezoic-ad-fallback">
    <span class="ad-label">Advertisement</span>
  </div>
</div>

<style>
  .ezoic-ad-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 90px;
    margin: var(--space-8) 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .ezoic-ad-fallback {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-height: 90px;
    background: var(--color-bg-card);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .ad-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
  }
</style>
