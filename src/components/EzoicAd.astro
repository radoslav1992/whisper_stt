---
interface Props {
  slotId: number;
  className?: string;
}

const { slotId, className = '' } = Astro.props;
---

<!-- Ad placeholder (hidden until ads are enabled) -->
<div
  class:list={['ezoic-ad-wrapper', className]}
  id={`ezoic-pub-ad-placeholder-${slotId}`}
  style="display: none;"
>
</div>
