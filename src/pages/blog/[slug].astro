---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EzoicAd from '../../components/EzoicAd.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} — AdWhisper Blog`}
  description={post.data.description}
  canonicalUrl={`/blog/${post.slug}`}
>
  <article class="section">
    <div class="container">
      <div class="article-header animate-fade-in">
        <a href="/blog" class="back-link">← Back to Blog</a>

        <div class="article-meta">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {post.data.readTime && <span class="article-read-time">{post.data.readTime}</span>}
          <span class="article-author">by {post.data.author}</span>
        </div>

        <h1>{post.data.title}</h1>

        <div class="article-tags">
          {post.data.tags.map((tag) => (
            <span class="blog-tag">{tag}</span>
          ))}
        </div>
      </div>

      <EzoicAd slotId={401} />

      <div class="prose animate-fade-in animate-delay-1">
        <Content />
      </div>

      <EzoicAd slotId={402} />

      <!-- Related CTA -->
      <div class="article-cta glass-card animate-fade-in animate-delay-2">
        <h3>Ready to Try It?</h3>
        <p>Transcribe or translate audio for free with AdWhisper. 100% private, runs in your browser.</p>
        <a href="/transcribe" class="btn btn-primary">🎙️ Start Transcribing</a>
      </div>

      <EzoicAd slotId={403} />
    </div>
  </article>
</BaseLayout>

<style>
  .article-header {
    max-width: 720px;
    margin: 0 auto var(--space-8);
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-primary-light);
  }

  .article-meta {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .article-meta time,
  .article-author {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .article-read-time {
    font-size: var(--text-xs);
    color: var(--color-primary-light);
    background: var(--color-primary-glow);
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-full);
  }

  .article-header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .article-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .blog-tag {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: var(--color-bg-card);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  .article-cta {
    max-width: 720px;
    margin: var(--space-12) auto 0;
    text-align: center;
    padding: var(--space-10);
  }

  .article-cta h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .article-cta p {
    margin-bottom: var(--space-4);
  }
</style>
